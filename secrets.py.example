# Copy this file to secrets.py and fill in your MyTravelMap credentials.
# secrets.py is git-ignored and must never be committed.
# Request your own application key/secret from the MyTravelMap developers page:
#   https://www.mytravelmap.xyz/developers

# --- World-map generation API (mytravelmap.py) ---
APP_KEY = "yourAppKey"
APP_SHARED_SECRET = "yourSharedSecret"

# Your public user ID, used by `mytravelmap.py --countries`.
# It is the last part of your Permalink (left menu -> Permalink) once logged in,
# e.g. https://www.mytravelmap.xyz/u/123e4567-... -> USER_ID = "123e4567-..."
USER_ID = "your-public-user-id"

# --- Website login, used to scrape your countries (scrape_countries.py) ---
EMAIL = "you@example.com"
PASSWORD = "your-password"
